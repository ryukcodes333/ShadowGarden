# ─── Supabase (real leaderboard) ───────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Shoob Card API (real cards in Summon) ─────────────────────────────────────
# URL of your deployed Shoob scraper API (e.g. on Render)
VITE_SHOOB_API_URL=https://your-shoob-api.onrender.com

# Without these set, the site falls back to beautiful mock data automatically.
